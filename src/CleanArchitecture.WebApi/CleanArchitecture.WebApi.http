@baseUrl = http://localhost:5000

### Health check
GET {{baseUrl}}/health

### Register
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "User1234!",
  "firstName": "Test",
  "lastName": "User"
}

### Login (access + refresh tokens arrive as HttpOnly cookies)
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "admin@example.com",
  "password": "Admin123!"
}

### Refresh (uses the cookie set by login)
POST {{baseUrl}}/api/v1/auth/refresh

### Me (access token cookie is sent automatically)
GET {{baseUrl}}/api/v1/auth/me

### Change password
POST {{baseUrl}}/api/v1/auth/change-password
Content-Type: application/json

{
  "currentPassword": "Admin123!",
  "newPassword": "NewAdmin123!"
}

### Logout
POST {{baseUrl}}/api/v1/auth/logout

### Users (Admin only)
GET {{baseUrl}}/api/v1/users?page=1&pageSize=20
